    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output || '';\n\n// Clean the output\nlet cleanOutput = output\n  .replace(/\\*\\*/g, '')           // Remove **bold**\n  .replace(/- /g, '')             // Remove bullet points\n  .replace(/\\|/g, '')             // Remove table characters\n  .replace(/#/g, '')              // Remove markdown headings\n  .replace(/\\\\n/g, '\\n')          // Fix new lines\n  .replace(/\\n{3,}/g, '\\n\\n')     // Remove extra empty lines\n  .replace(/\\s+/g, ' ')           // Remove extra spaces\n  .trim();                        // Remove leading/trailing spaces\n\n// Format: Field: Value on each line\nconst lines = cleanOutput.split('\\n');\nconst formattedLines = lines.map(line => line.trim()).filter(line => line.length > 0);\nconst finalOutput = formattedLines.join('\\n');\n\nreturn {\n  output: finalOutput\n};"
      },
      "type": "n8n-nodes-base.code",
